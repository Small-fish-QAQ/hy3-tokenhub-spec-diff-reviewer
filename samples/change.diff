@@ -0,0 +1,22 @@
+'use strict';
+
+const CATEGORY_OWNERS = {
+  billing: 'payments',
+  security: 'security',
+  support: 'support'
+};
+
+function routeTask(task, allowedTeams) {
+  const owner = CATEGORY_OWNERS[task.category] || 'general';
+
+  return {
+    status: 'assigned',
+    owner,
+    escalation: null,
+    reason: `Routed "${task.title}" by category`
+  };
+}
+
+module.exports = {
+  routeTask
+};
