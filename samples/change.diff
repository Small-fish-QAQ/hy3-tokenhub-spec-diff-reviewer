@@ -0,0 +1,15 @@
+'use strict';
+
+const test = require('node:test');
+const assert = require('node:assert/strict');
+const { routeTask } = require('../src/route-task');
+
+test('routes a billing task to payments', () => {
+  const result = routeTask(
+    { title: 'Invoice failed', category: 'billing', priority: 'normal' },
+    ['payments', 'support']
+  );
+
+  assert.equal(result.status, 'assigned');
+  assert.equal(result.owner, 'payments');
+});
