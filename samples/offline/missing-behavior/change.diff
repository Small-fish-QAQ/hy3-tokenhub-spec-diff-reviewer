new file mode 100644
index 0000000..e32c172
--- /dev/null
+++ b/src/session.js
@@ -0,0 +1,5 @@
+export function sessionStatus(lastSeen, now) {
+  const elapsed = now - lastSeen;
+  return elapsed > 30 * 60 * 1000 ? 'expired' : 'active';
+}
