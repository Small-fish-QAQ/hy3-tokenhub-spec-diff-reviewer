{
  "name": "hy3-tokenhub-spec-diff-reviewer",
  "version": "1.0.0",
  "description": "A small Hy3 spec-to-diff review CLI using Tencent Cloud TokenHub.",
  "main": "hy3_showcase.js",
  "scripts": {
    "test": "node --test",
    "review:sample": "node hy3_showcase.js diff-review --spec samples/issue.md --diff samples/change.diff",
    "review:sample:no-stream": "node hy3_showcase.js diff-review --spec samples/issue.md --diff samples/change.diff --no-stream"
  },
  "keywords": [
    "hy3",
    "tokenhub",
    "tencent-cloud"
  ],
  "author": "",
